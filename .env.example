# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Service role key (bypass RLS) — utilisé par les routes cron et les jobs admin.
# À générer dans Supabase > Project Settings > API > service_role.
# Ne JAMAIS exposer côté client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret partagé entre Vercel Cron et la route /api/cron/notifications.
# Vercel injecte le header "Authorization: Bearer $CRON_SECRET" automatiquement
# quand la variable est définie dans le projet Vercel.
CRON_SECRET=generate-a-long-random-string
